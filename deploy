#!/bin/bash
# deploy: push style.css/live.js/loader.js and purge jsDelivr (serves from repo, no Pages)
set -e
cd "$(dirname "$0")"
git add -A
git commit -m "${1:-update}

Co-Authored-By: Claude Fable 5 <noreply@anthropic.com>" || true
git push -q
for f in loader.js style.css live.js; do
  curl -s "https://purge.jsdelivr.net/gh/mohdshehri-dev/mohdshehri-blog-style@main/$f" > /dev/null
done
echo "✓ live via jsDelivr (readers fresh within 10 min)"
